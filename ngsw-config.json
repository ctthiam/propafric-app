{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "icons-fonts",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/icons/**",
          "/assets/**"
        ],
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-dashboard",
      "urls": [
        "/api/agency/dashboard",
        "/api/agency/properties",
        "/api/agency/leases",
        "/api/agency/tenants",
        "/api/agency/rent-schedules"
      ],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "1h",
        "timeout": "8s",
        "strategy": "freshness"
      }
    },
    {
      "name": "api-payments",
      "urls": [
        "/api/agency/rent-payments",
        "/api/agency/expenses"
      ],
      "cacheConfig": {
        "maxSize": 5,
        "maxAge": "30m",
        "timeout": "8s",
        "strategy": "freshness"
      }
    }
  ],
  "navigationRequestStrategy": "freshness"
}
